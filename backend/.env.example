# Jira Configuration (REQUIRED)
JIRA_BASE_URL=https://engjira.int.kronos.com
JIRA_PAT=your-jira-pat-token-here

# Claude API (OPTIONAL - only needed for chat feature)
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL_NAME=claude-sonnet-4-6

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DB_PATH=../database/protime.db

# Slack Integration (OPTIONAL - for alerts)
# Bot token from https://api.slack.com/apps - starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL_ID=C09861JGVQF
